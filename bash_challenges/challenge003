#!/bin/bash

#Todays challenge - using the data.txt file - read in the file and write a bash script to create a sum of the numbers - hint, the sum should be 536. If your result is wrong, #why is it wrong and how did you fix it?

#data.txt

#102
#071
#210
#153

#buffer=$(cat 'data.txt')
#echo "$buffer"
#echo " "
#sum 'data.txt'

awk '{s+=$1} END {print s}' data.txt

# awk processes a file line by line. Here's the breakdown:

#  - `'{s+=$1} END {print s}'` — the awk program, in two parts:
#    - `{s+=$1}` — the main rule, runs on every line:
#      - $1 = the first field (word) on the current line
#      - s+=$1 = add it to the variable s (awk variables start at 0 automatically)

#    - `END {print s}` — runs once after all lines are processed:
#      - prints the final value of s

#  - `data.txt` — the input file

#  So with your file:

#  102    → s = 0 + 102 = 102
#  071    → s = 102 + 71  = 173
#  210    → s = 173 + 210 = 383
#  153    → s = 383 + 153 = 536
#  END    → print 536

#  Output: 536

#Or we can do:

 sum=0
  while read -r num; do
    sum=$((sum + 10#$num))
  done < data.txt
  echo "$sum"

# The gotcha: 071 in bash arithmetic is interpreted as octal (base 8), which equals 57 in decimal. Without the fix, you'd get 522 instead of 536.

# The fix: 10#$num forces bash to treat every number as base 10, so 071 = 71.
#Or:

items2Array=($(cat data.txt))

sum=0
for i in {0..3}; do
  value=$(echo "${items2Array[i]}" | sed 's/^0*//')
  sum=$(( $sum + $value ))
 # echo $sum
  done
  echo $sum
